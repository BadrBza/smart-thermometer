<Window Width="1150"
        Height="700"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        xmlns:views="clr-namespace:Stas.Monitor.Views"
        mc:Ignorable="d"
        d:DesignWidth="800"
        d:DesignHeight="450"
        x:Class="Stas.Monitor.Views.MainWindow"
        x:CompileBindings="False"
        Title="Stas.Monitor"
        Background="#1D1D1D">
    <Window.Resources>
        <views:DifferenceDisplayConverter x:Key="DifferenceDisplayConverter" />
        <views:AlertDifferenceDisplayConverter x:Key="AlertDifferenceDisplayConverter"/>
        <views:ValueToColorConverter x:Key="ValueToColorConverter"/>
    </Window.Resources>

    <Grid Background="#1C1C1E" HorizontalAlignment="Center" VerticalAlignment="Top">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- For Expander and Filters -->
            <RowDefinition Height="*"/>    <!-- For Content -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/> <!-- For temperature ListBox -->
            <ColumnDefinition Width="*"/> <!-- For humidity ListBox -->
        </Grid.ColumnDefinitions>

        <!-- Expander for display options -->
        <Expander Grid.ColumnSpan="2"
          Header="Options d'affichage"  FontWeight="Regular" CornerRadius="15" 
          IsExpanded="True" 
          ExpandDirection="Down"
          HorizontalAlignment="Stretch">
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="60">
        <!-- Filtre pour la liste des thermomètres -->
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="Liste des thermomètres:" Foreground="#FFFFFF" FontSize="14"  FontWeight="UltraLight" />
            <ComboBox Width="300"
                      x:Name="ThermometerSelector"
                      ItemsSource="{Binding ThermometerNames}"
                      SelectedItem="{Binding SelectedThermometerName}"
                      Background="#3A3A3C"
                      Foreground="#FFFFFF"
                      BorderBrush="#5A5A5D"
                      FontWeight="UltraLight"
                      BorderThickness="1"
                      CornerRadius="12"/>
        </StackPanel>

        <!-- Filtre pour les séries (températures et humidité) -->
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="Séries disponibles:" Foreground="#FFFFFF" FontSize="14"  FontWeight="UltraLight" />
            <CheckBox Content="Températures" FontWeight="Light"
                      IsChecked="{Binding ShowTemperatureMeasurements}"
                      Foreground="#FFFFFF"/>
            <CheckBox Content="Humidité" FontWeight="Light"
                      IsChecked="{Binding ShowHumidityMeasurements}"
                      Foreground="#FFFFFF"/>
        </StackPanel>

        <!-- Filtre pour la durée -->
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="Durée:" Foreground="#FFFFFF" FontSize="14" FontWeight="UltraLight" />
            <ComboBox x:Name="DurationComboBox" 
                      SelectionChanged="DurationComboBox_SelectionChanged"
                      CornerRadius="10"
                      Width="140"> 
                <ComboBoxItem Content="30 secondes" Tag="00:00:30"/>
                <ComboBoxItem Content="1 minute" Tag="00:01:00" IsSelected="True"/>
                <ComboBoxItem Content="5 minutes" Tag="00:05:00"/>
            </ComboBox>
        </StackPanel>

    </StackPanel>
</Expander>
        
        <TextBlock Grid.Column="0" Grid.Row="1" 
                   Text="Température :" 
                   Foreground="#FFFFFF" 
                   FontSize="16" 
                   FontWeight="UltraLight" 
                   HorizontalAlignment="Center"
                   Margin="10,45,40,5"/>
        <!-- Temperature ListBox -->
        <ListBox Grid.Column="0" Grid.Row="1"
                 ItemsSource="{Binding SelectedTemperatureEvents}"
                 Width="550"
                 Height="400"
                 x:Name="TemperatureListBox"
                 Margin="10,10,5,7"
                 Background="#1C1C1E"
                 BorderBrush="#5A5A5D"
                 Opacity="0.95"
                 BorderThickness="2"
                 CornerRadius="23"
                 Padding="12"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <!-- DataTemplate for temperatures -->
            <ListBox.ItemTemplate>
        <DataTemplate>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Grouping Value and Actual Temperature -->
                <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="5">
                    <!-- Display the temperature -->
                    <TextBlock Text="{Binding Temperature, StringFormat={}{0:F2}°}" 
                               Foreground="#D0D0D0" 
                               FontWeight="Regular" 
                               FontSize="16" 
                               Width="60" 
                               TextAlignment="Right"/>
                </StackPanel>
                
                <!--<TextBlock Text="{Binding Temperature, StringFormat={}{0:F2}%}" 
                           Foreground="#FF6B6B" 
                           FontWeight="Regular" 
                           FontSize="16" 
                           Width="60" 
                           TextAlignment="Right"/>-->

                <!-- Display the date -->
                <TextBlock Grid.Column="1" Text="{Binding Timestamp, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" 
                           Foreground="#B0B0B0" 
                           FontWeight="Regular" 
                           Margin="60,0,0,0"
                           FontSize="14" 
                           TextAlignment="Left"/>

                <!-- Display the expected temperature if it's an alert -->
                <TextBlock Grid.Column="2" Text="{Binding Difference, Converter={StaticResource DifferenceDisplayConverter}}" 
                           Foreground="{Binding Difference, Converter={StaticResource ValueToColorConverter}}" 
                           FontWeight="Regular" 
                           FontSize="14" 
                           Margin="0,0,30,0"
                           TextAlignment="Right"/>
            </Grid>
        </DataTemplate>
    </ListBox.ItemTemplate>
            <!-- ... -->
        </ListBox>

        <TextBlock Grid.Column="1" Grid.Row="1"
                   Text="Taux d'humidité :" 
                   Foreground="#FFFFFF" 
                   FontSize="16" 
                   FontWeight="UltraLight" 
                   HorizontalAlignment="Center"
                   Margin="10,45,5,7"/>
        <!-- Humidity ListBox -->
      <ListBox Grid.Column="1" Grid.Row="1"
         ItemsSource="{Binding SelectedHumidityEvents}"
         Width="550"
         Height="400"
         Margin="10,80,5,80"
         Background="#1C1C1E"
         BorderBrush="#5A5A5D"
         Opacity="0.95"
         BorderThickness="2"
         CornerRadius="23"
         Padding="12"
         HorizontalAlignment="Center"
         VerticalAlignment="Center">
    <!-- DataTemplate for humidity -->
    <ListBox.ItemTemplate>
        <DataTemplate>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Grouping Value and Actual Temperature -->
                <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="5">
                    <!-- Display the temperature -->
                    <TextBlock Text="{Binding Humidity, StringFormat={}{0:F2}%}" 
                               Foreground="#D0D0D0" 
                               FontWeight="Regular" 
                               FontSize="14" 
                               Width="60" 
                               TextAlignment="Right"/>
                </StackPanel>
                <!--<TextBlock Text="{Binding ActualTemperature, StringFormat={}{0:F2}%}" 
                           Foreground="#FF6B6B" 
                           FontWeight="Regular" 
                           FontSize="16" 
                           Width="60" 
                           TextAlignment="Right"/>-->

                <!-- Display the date -->
                <TextBlock Grid.Column="1" Text="{Binding Timestamp, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" 
                           Foreground="#B0B0B0" 
                           FontWeight="Regular" 
                           Margin="60,0,0,0"
                           FontSize="14" 
                           TextAlignment="Left"/>

                <!-- Display the expected temperature if it's an alert -->
                <TextBlock Grid.Column="2" Text="{Binding AlertDifference, Converter={StaticResource AlertDifferenceDisplayConverter}}" 
                           Foreground="{Binding AlertDifference, Converter={StaticResource ValueToColorConverter}}" 
                           FontWeight="Regular" 
                           FontSize="14" 
                           Margin="0,0,30,0"
                           TextAlignment="Right"/>
            </Grid>
        </DataTemplate>
    </ListBox.ItemTemplate>
</ListBox>

    </Grid>
</Window>
